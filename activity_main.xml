<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B2A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center">

        <!-- Título -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚽ Sorteio de Jogadores"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Clique no botão e descubra seu craque!"
            android:textSize="13sp"
            android:textColor="#90A4AE"
            android:gravity="center"
            android:layout_marginBottom="32dp"/>

        <!-- Botão Sortear -->
        <Button
            android:id="@+id/btnSortear"
            android:layout_width="220dp"
            android:layout_height="54dp"
            android:text="SORTEAR JOGADOR"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#0D1B2A"
            android:backgroundTint="#FFD700"
            android:layout_marginBottom="32dp"/>

        <!-- Card Resultado -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardResultado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#1A2E42"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp">

                <!-- Número sorteado -->
                <TextView
                    android:id="@+id/tvNumero"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:gravity="center"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="#0D1B2A"
                    android:background="@drawable/bg_numero"
                    android:layout_marginBottom="20dp"/>

                <!-- Foto do jogador -->
                <ImageView
                    android:id="@+id/ivJogador"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_foto"
                    android:layout_marginBottom="20dp"/>

                <!-- Nome -->
                <TextView
                    android:id="@+id/tvNome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:layout_marginBottom="8dp"/>

                <!-- Posição -->
                <TextView
                    android:id="@+id/tvPosicao"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="#FFD700"
                    android:gravity="center"
                    android:layout_marginBottom="4dp"/>

                <!-- Nacionalidade -->
                <TextView
                    android:id="@+id/tvNacionalidade"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="#90A4AE"
                    android:gravity="center"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>